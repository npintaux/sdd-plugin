{
  "hooks": {
    "UserPromptExpansion": [
      {
        "matcher": "specify",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/pre-specify.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/post-specify.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
